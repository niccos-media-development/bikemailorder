<div class="section" >
  <div class="container">
    <h1 class="collection-banner__heading mb-0 inline">{{ section.settings.headline }}</h1>
     <span class="font-heading collection-banner__count block">
       ({{ 'sections.collection.product_count.other' | t: count: collection.all_products_count }})
     </span>
    <p>{{ section.settings.description }}</p>
  </div>
</div>


{% stylesheet %}

  
  
{% endstylesheet %}



{% schema %}
  {
    "name": "Hoco Collection Intro",
    "settings": [
      {
        "type": "text",
        "id": "headline",
        "label": "Überschrift"
      },
      {
        "type": "text",
        "id": "description",
        "label": "Beschreibung"
      },
    ],
    "presets": [{"name": "Hoco Collection Intro"}]  
  }
{% endschema %}