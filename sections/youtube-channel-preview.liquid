<script>
var channelID = "UC4FkW6lvJEP0fUe8WGmGxJg";
var reqURL = "https://www.youtube.com/feeds/videos.xml?channel_id=";
$.getJSON("https://api.rss2json.com/v1/api.json?rss_url=" + encodeURIComponent(reqURL)+channelID, function(data) {
   var link = data.items[0].link;
   var id = link.substr(link.indexOf("=")+1);
$("#youtube_video1").attr("src","https://youtube.com/embed/"+id + "?controls=0&showinfo=0&rel=0");
});
</script>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/2.1.1/jquery.min.js"></script>

 <div class="section" >
  <div class="container">
    <ul class=" flex flex-wrap gap-x-theme gap-y-12 md:gap-y-6">
      <li class="multi-column grow w-full max-w-none cc-animate-init cc-animate-in">
        <h1>{{ section.settings.headline }}</h1>
        <p>{{ section.settings.text }}</p>
      </li>
      <li class="multi-column grow w-full max-w-none cc-animate-init cc-animate-in">
        <iframe id="youtube_video1" width="600" height="340" frameborder="0" allowfullscreen></iframe>
      </li>
    </ul>
  </div>
</div>


