<div class="section youtube-preview" style="padding:{{ section.settings.padding }} 0" >
  <div class="container">
    <ul>
      <li>
        <h1>{{ section.settings.headline }}</h1>
        <p>{{ section.settings.text }}</p>
        <div>
          <div>
          </div>
          <div>
            <p><strong>BMO Bike Mailorder</strong></p>
          </div>
          <div>
            <a class="btn btn--primary" href="https://www.youtube.com/@bmobikemailorder5907?sub_confirmation=1">
              <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bi bi-youtube" viewBox="0 0 16 16">
                <path d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172.883.22 1.402l.01.104.022.26.008.104c.065.914.073 1.77.074 1.957v.075c-.001.194-.01 1.108-.082 2.06l-.008.105-.009.104c-.05.572-.124 1.14-.235 1.558a2.01 2.01 0 0 1-1.415 1.42c-1.16.312-5.569.334-6.18.335h-.142c-.309 0-1.587-.006-2.927-.052l-.17-.006-.087-.004-.171-.007-.171-.007c-1.11-.049-2.167-.128-2.654-.26a2.01 2.01 0 0 1-1.415-1.419c-.111-.417-.185-.986-.235-1.558L.09 9.82l-.008-.104A31 31 0 0 1 0 7.68v-.123c.002-.215.01-.958.064-1.778l.007-.103.003-.052.008-.104.022-.26.01-.104c.048-.519.119-1.023.22-1.402a2.01 2.01 0 0 1 1.415-1.42c.487-.13 1.544-.21 2.654-.26l.17-.007.172-.006.086-.003.171-.007A100 100 0 0 1 7.858 2zM6.4 5.209v4.818l4.157-2.408z"/>
              </svg>
              Jetzt Abonieren
            </a>
          </div>
        </div>
        
      </li>
      <li class="yt-wrapper" >
        <iframe src="https://www.youtube.com/embed/{{ section.settings.youtube1 }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </li>
      <li class="yt-wrapper">
        <iframe src="https://www.youtube.com/embed/{{ section.settings.youtube2 }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </li>
    </ul>
  </div>
</div>


{% stylesheet %}
  
.youtube-preview.section {
  background: #000;
}
.youtube-preview.section ul {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(800px, 1fr)) repeat(auto-fit, minmax(300px, 1fr)) repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  align-items:center;
}
.youtube-preview.section ul li h1, .section ul li p {
  color: #fff;
}

.youtube-preview.section ul li a {
    display: flex;
    width: fit-content;
    align-items: center;
}
.youtube-preview.section ul li a svg {
    width: 24px;
    margin-right: 11px;
}

.youtube-preview.section ul li.yt-wrapper {
  position: relative;
  padding-bottom: 56.25%;
  /* 16:9 */
  padding-top: 25px;
  height: 0;
}

.youtube-preview.section ul li iframe {
    position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  }
  
{% endstylesheet %}



{% schema %}
  {
    "name": "Youtube Channel Preview",
    "settings": [
      {
        "type": "text",
        "id": "headline",
        "label": "Überschrift"
      },
      {
        "type": "text",
        "id": "text",
        "label": "Text",
      },
      {
        "type": "text",
        "id": "youtube1",
        "label": "Youtube ID 1",
      },
      {
        "type": "text",
        "id": "youtube2",
        "label": "Youtube ID 2",
      },
      {
        "type": "text",
        "id": "padding",
        "label": "Abstand Oben/Unten",
      } 
    ],
    "presets": [{"name": "Youtube Preview"}]  
  }
{% endschema %}