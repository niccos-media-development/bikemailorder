{%- comment -%}
  Section: Brand List
  Diese Section zeigt Marken aus Metafields an, sortiert nach Alphabet.
{%- endcomment -%}

{%- assign brands = "" | split: "" -%}

{%- comment -%}
  Sammle alle Marken aus den Produkten
{%- endcomment -%}
{%- for product in collections.all.products -%}
  {%- assign brand = product.vendor -%}
  {%- unless brands contains brand -%}
    {%- assign brands = brands | push: brand -%}
  {%- endunless -%}
{%- endfor -%}

{%- comment -%}
  Sortiere die Marken alphabetisch
{%- endcomment -%}
{%- assign brands = brands | sort_natural -%}

{%- comment -%}
  Gruppiere die Marken nach Anfangsbuchstaben
{%- endcomment -%}
{%- assign grouped_brands = brands | group_by: "first_letter" -%}

{%- comment -%}
  Erstelle die Navigation
{%- endcomment -%}
<div class="brand-navigation">
  <ul>
    {%- for group in grouped_brands -%}
      <li><a href="#{{ group.name }}">{{ group.name }}</a></li>
    {%- endfor -%}
  </ul>
</div>

{%- comment -%}
  Zeige die Markenliste an
{%- endcomment -%}
<div class="brand-list">
  {%- for group in grouped_brands -%}
    <h2 id="{{ group.name }}">{{ group.name }}</h2>
    <ul>
      {%- for brand in group.items -%}
        <li>{{ brand }}</li>
      {%- endfor -%}
    </ul>
  {%- endfor -%}
</div>

<style>
  .brand-navigation {
    margin-bottom: 20px;
  }
  .brand-navigation ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .brand-navigation ul li a {
    text-decoration: none;
    color: #000;
    font-weight: bold;
  }
  .brand-list h2 {
    margin-top: 30px;
    margin-bottom: 10px;
    font-size: 24px;
  }
  .brand-list ul {
    list-style: none;
    padding: 0;
  }
  .brand-list ul li {
    margin-bottom: 5px;
  }
</style>

{% schema %}
  {
    "name": "Hoco Brand List",
    "settings": [],
    "presets": [{"name": " Hoco Brand List"}] 
  }
{% endschema %}