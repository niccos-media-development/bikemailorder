<div class="section newsletter-sign-up" style="background-color:{{ section.settings.background-color }};">
  <div class="container">
    <h2 style="color:{{ section.settings.text-color }}!important">{{ section.settings.headline }}</h2>
    <div class="klayvio-form">
      {{ section.settings.form }}
      <form><input></form><button></button>
    </div>
  </div>
</div>

{% stylesheet %}

.klayvio-form {
  display: flex;
  justify-content: center;
}
.section.newsletter-sign-up {
  padding: 40px 0;
}
@media (max-width:768px;) {
  .section.newsletter-sign-up {
    padding: 100px 0;
  }
}

.section.newsletter-sign-up h2 {
  text-align: center;
}
  
{% endstylesheet %}

{% schema %}
  {
    "name": "Hoco Newsletter Sign Up",
    "settings": [
      {
        "type": "text",
        "id": "headline",
        "label": "Überschrift"
      },
      {
        "type": "color",
        "id": "background-color",
        "label": "Hintergrundfarbe",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "text-color",
        "label": "Textfarbe",
        "default": "#000000"
      },
      {
        "type": "html",
        "id": "form",
        "label": "Klayvio Forumlar"
      },
    ],
    "presets": [{"name": " Hoco Newsletter Sign Up"}]  
  }
{% endschema %}