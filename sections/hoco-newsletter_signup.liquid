<div class="section" style="background-color:{{ section.settings.background-color }}">
  <div class="container">
    <h2>{{ section.settings.headline }}</h2>
    <div>
      {{ section.settings.form }}
    </div>
  </div>
</div>



{% schema %}
  {
    "name": "Hoco Newsletter Sign Up",
    "settings": [
      {
        "type": "text",
        "id": "headline",
        "label": "Überschrift"
      },
      {
        "type": "color",
        "id": "background-color",
        "label": "Hintergrunfarbe",
        "default": "#000000"
      },
      {
        "type": "html",
        "id": "form",
        "label": "Klayvio Forumlar"
      },
    ],
    "presets": [{"name": " Hoco Newsletter Sign Up"}]  
  }
{% endschema %}